<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Märge: {{title}}</title></head>
<body style="font-family:sans-serif;max-width:560px;margin:0 auto;padding:32px 24px;color:#1a1a1a">
  <h2 style="margin-top:0">{{title}}</h2>
  {{#if category}}
  <p style="margin:4px 0 16px;color:#666;font-size:13px">Kategooria: <strong>{{category}}</strong></p>
  {{/if}}
  <div style="background:#f7f7f7;padding:16px;border-radius:4px;white-space:pre-wrap;line-height:1.6;margin:16px 0">{{content}}</div>
  <p style="color:#999;font-size:13px">Autor: {{author}}</p>
  {{#if hasAttachments}}
  <p style="color:#555;font-size:13px">
    📎 {{attachmentCount}} fail(i) lisatud meilimanusena.
  </p>
  {{/if}}
  <hr style="border:none;border-top:1px solid #eee;margin:28px 0">
  <p style="color:#999;font-size:12px;margin:0">Ground Zero</p>
</body>
</html>
